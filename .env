# Environment Configuration
# File này được share cho tất cả team members

# Auto-deployment
AUTO_DEPLOY=true

# Transfer Learning (AUTO-ENABLED FOR ALL MEMBERS)
USE_TRANSFER_LEARNING=true
AUTO_MERGE_DATA=true

# Model Registry
REGISTRY_DIR=model_registry

# Training defaults (OPTIMIZED FOR TRANSFER LEARNING)
DEFAULT_EPOCHS=3
DEFAULT_BATCH_SIZE=16
DEFAULT_LEARNING_RATE=2e-5
