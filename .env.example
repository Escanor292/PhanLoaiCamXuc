# Environment Configuration
# Copy file này thành .env và chỉnh sửa theo nhu cầu

# Auto-deployment
# true = Tự động deploy model tốt nhất sau khi training
# false = Phải deploy thủ công
AUTO_DEPLOY=true

# Model Registry
REGISTRY_DIR=model_registry

# Training defaults
DEFAULT_EPOCHS=5
DEFAULT_BATCH_SIZE=16
DEFAULT_LEARNING_RATE=2e-5
