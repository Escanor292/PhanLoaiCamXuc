# Data files - IMPORTANT: Each member only commits their own CSV
# Other members' CSV files are NOT pulled to avoid duplicate training
data/*.csv
data/*.txt
data/*.json
!data/.gitkeep
!data/TEMPLATE_DONG_GOP_DATA.csv  # Template - always pull
!data/sample_comments.csv          # Sample data - always pull
# Note: Member CSV files (member_*.csv) are ignored by default
# Each member only has their own CSV file locally
data/merged_temp.csv  # Temporary merged file

